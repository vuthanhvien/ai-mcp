# Ollama server URL. Default is local Ollama.
OLLAMA_HOST=http://localhost:11434

# HTTP server port.
PORT=8000

# Default model for /api/chat.
CHAT_MODEL=qwen3-coder:30b

# Required for public usage. Generate a long random value.
API_KEY=change-me

# Comma-separated origins allowed to call /api/chat from browsers.
# Use * for quick testing, or set your real domains:
# CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=*
